strict digraph {
GRADUATION_YEAR;
SCORE_NEM;
GRADE_PERCENTILE;
GENDER;
HOW_MANY_WORK;
HOW_MANY_STUDY;
PREVIOUS_ADMISSION;
SCHOOL_TYPE;
SCHOOL_DEPENDENCY;
WORK;
RURAL;
GRADUATION_YEAR -> SCORE_NEM;
GRADE_PERCENTILE -> GRADUATION_YEAR;
GENDER -> GRADE_PERCENTILE;
GENDER -> WORK;
HOW_MANY_WORK -> PREVIOUS_ADMISSION;
HOW_MANY_STUDY -> SCHOOL_TYPE;
PREVIOUS_ADMISSION -> GRADUATION_YEAR;
SCHOOL_TYPE -> GRADE_PERCENTILE;
SCHOOL_TYPE -> SCHOOL_DEPENDENCY;
SCHOOL_DEPENDENCY -> WORK;
WORK -> HOW_MANY_WORK;
RURAL -> SCHOOL_TYPE;
}
